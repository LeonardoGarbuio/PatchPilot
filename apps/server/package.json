{
  "name": "@patchpilot/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^11.1.0",
    "@patchpilot/agent": "workspace:*",
    "@patchpilot/git": "workspace:*",
    "@patchpilot/sandbox": "workspace:*",
    "@patchpilot/shared": "workspace:*",
    "@patchpilot/tools": "workspace:*",
    "adm-zip": "^0.5.16",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.3.2",
    "nanoid": "^5.0.9",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.0.4"
  }
}
